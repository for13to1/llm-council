# ============================================================
# LLM Council - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
#
# All providers are configured the same way — OpenRouter is just one of them.
# Each provider's base_url can be overridden for relays/proxies.
# ============================================================


# --- OpenRouter (aggregator — access many models with one key) ---
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions


# --- OpenAI ---
# https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions


# --- Anthropic ---
# https://console.anthropic.com/settings/keys
# Uses native Messages API (not OpenAI-compatible), handled by llm_client adapter
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1/messages


# --- Google Gemini ---
# https://aistudio.google.com/apikey
# GOOGLE_API_KEY=...
# GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions


# --- xAI (Grok) ---
# https://console.x.ai/
# XAI_API_KEY=...
# XAI_BASE_URL=https://api.x.ai/v1/chat/completions


# --- DeepSeek ---
# https://platform.deepseek.com/api_keys
# DEEPSEEK_API_KEY=...
# DEEPSEEK_BASE_URL=https://api.deepseek.com/chat/completions


# --- Ollama (local) ---
# No API key needed. Install: https://ollama.com/download
# OLLAMA_BASE_URL=http://localhost:11434/v1/chat/completions
